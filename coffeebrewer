#!/bin/sh
#Phase 1
#
yayinstall='arch-chroot /mnt sudo -Su $user01 yay --noconfirm --nodiffmenu --noremovemake --answerclean y  --answerdiff y --answeredit y --answerupgrade y'
pacstrapinstall='pacstrap /mnt'
pacmaninstall='arch-chroot /mnt pacman -Sy'
systemdenable='arch-chroot /mnt systemctl enable'
#echo "This script/command must be run directly as root user not via sudo. (ie: entering sudo -i first)"
#echo "If you have not ran as root user, please exit now, root, and run again."
#
echo -e "" | sudo -i

echo "Set your Username."
read user00
user01=$user00

echo "Set your User Password."
read userpass00
userpass0=$userpass00

echo "Set your Root Password."
read userpass01
userpass1=$userpass01

#
echo "Set your PC name."
read name00
name0=$name00
#
echo "Set your HardDrive name."
read name01
name1=$name01
#
echo "Is this a CoffeeLinux Installer .iso/USB? -- yes or no."
read native01
native1=$native01
#

echo 'Listing Storage Devices for you.'
fdisk -l
read -n 1 -s -r -p "Press any key to continue with OS installation." &&
echo ' ' && 

echo "Set your drive ('nvme0n1 or nvme1n1 / sda or sdb'). Do not include partition number."
read drive
pfx="/dev/"
drive0=$pfx$drive
#

if [ $drive == 'nvme0n1' ]
then
boot=p1
swap=p2
system=p3
elif [ $drive == 'nvme1n1' ]
then
boot=p1
swap=p2
system=p3
elif [ $drive == 'sda' ]
then
boot=1
swap=2
system=3
elif [ $drive == 'sdb' ]
then
boot=1
swap=2
system=3
else
echo 'You need to enter a valid drive'
fi
#
#
boot0=$drive0$boot
#
swap0=$drive0$swap
#
system0=$drive0$system
#
hostname0=$name0
#
drivename0=$name1
#

echo "Set your Swap Size -- ie: 8G for 8 Gigabytes of swapspace. protip: This should be equal to your RAM."
read swapsize
swap1=$swapsize
#
echo "What dektop environment would you like? gnome, or kde -- note:case-sensitive."
read desktop0
#

echo "Set the currently released major Java Version number -- 19 or newer."
read javaver
java0=$javaver

echo 'Do you have an amd or nvidia graphics card? case-sensitive -- Intel not yet supported.'
read gpu0

echo "Would you like to Zero-Out the drive first? -- yes or no. WARNING Zero-Out will take a long time, but has its benifits. "
read zerout0
#

if [ $zerout0 == 'yes' ]
then

echo 'Zero-Outing the drive... This will take quite a long time..' 

dd if=/dev/zero of=$drive0 bs=1M status=progress 

echo 'Zero-Out Complete.'

read -n 1 -s -r -p 'Press any key to continue with OS installation.' 

echo -e "g\nn\n1\n\n+2G\nn\n2\n\n+$swap1\nn\n3\n\n\nt\n1\n1\nt\n2\n19\nw" | fdisk -W always $drive0 

elif [ $zerout0 == 'no' ]
then
echo -e "g\nn\n1\n\n+2G\nn\n2\n\n+$swap1\nn\n3\n\n\nt\n1\n1\nt\n2\n19\nw" | fdisk -W always $drive0 

else
echo 'You need to choose yes or no here.'

fi

#
echo 'Formatting Partitions' && 
mkfs.fat -F32 $boot0 && 
mkswap $swap0
swapon $swap0
mkfs.btrfs -f -L $drivename0 $system0 && 
echo 'Mounting Disks' && 
mount $system0 /mnt && 
mkdir /mnt/boot && 
mount $boot0 /mnt/boot && 
echo 'Enable Repos' &&
echo '' >> /etc/pacman.conf &&
echo '[multilib]' >> /etc/pacman.conf && 
echo 'Include = /etc/pacman.d/mirrorlist' >> /etc/pacman.conf &&
echo '' >> /etc/pacman.conf &&
echo '[andontie-aur]' >> /etc/pacman.conf &&
echo 'Server = https://aur.andontie.net/$arch' >> /etc/pacman.conf &&
echo 'SigLevel = Never' >> /etc/pacman.conf &&
echo '' >> /etc/pacman.conf &&
pacman -Sy --noconfirm archlinux-keyring && 
pacman -Sy --noconfirm archlinux-appstream-data && 
#
#echo 'Installing Kernel Frameworks' && 
pacman -Syy && 
$pacstrapinstall base intel-ucode amd-ucode linux linux-firmware btrfs-progs net-tools networkmanager dhcpcd iwd man-pages man-db texinfo mkinitcpio sudo nano && 
$pacmaninstally &&
$pacmaninstall --noconfirm archlinux-keyring &&
cp /etc/pacman.conf /mnt/etc/pacman.conf &&
$pacmaninstally &&
#
echo 'Set Root Password' && 
echo -e "$userpass1\n$userpass1\n" | arch-chroot /mnt passwd && 
echo 'Adding User Account' && 
arch-chroot /mnt useradd -m -G wheel,audio,video,users --badname $user01 && 
echo 'Set User Password' && 
echo -e "$userpass0\n$userpass0\n" | arch-chroot /mnt passwd $user01
echo $hostname0 > /mnt/etc/hostname && 
echo '127.0.0.1 localhost' >> /mnt/etc/hosts && 
echo '::1 localhost' >> /mnt/etc/hosts && 
echo 127.0.1.1 $hostname0 >> /mnt/etc/hosts && 
#
echo 'Creating Links' && 
genfstab -U /mnt >> /mnt/etc/fstab &&
arch-chroot /mnt /bin/bash <<"EOT"
echo 'Setting Locale' && 
#read -n 1 -s -r -p "Press any key to continue" &&
ln -sf ../usr/share/zoneinfo/America/Los_Angeles /etc/localtime && 
hwclock --systohc && 
echo 'en_US ISO-8859-1' >> /etc/locale.gen && 
echo 'en_US.UTF-8 UTF-8' >> /etc/locale.gen && 
echo 'KEYMAP=us' > /etc/vconsole.conf && 
echo 'LANG=en_US.UTF-8' > /etc/locale.conf && 
export LANG=en_US.UTF-8 && 
locale-gen &&  
cd / &&  
echo '%wheel ALL=(ALL:ALL) NOPASSWD: ALL' > /etc/sudoers.d/wheel &&
mkinitcpio -P && 
echo $$
EOT

#
cp --dereference /etc/resolv.conf /mnt/etc/ &&
$pacmaninstall --noconfirm archlinux-appstream-data &&
$pacmaninstallu --noconfirm && 
#

if [ $desktop0 == 'gnome' ]
then
#
$pacmaninstall --noconfirm file-roller go xdg-desktop-portal-gnome xorg-xwayland libpulse qt6 qt6-wayland qt6-multimedia-ffmpeg lib32-libpulse alsa-plugins lib32-alsa-plugins alsa-lib lib32-alsa-lib gtk4 zenity gst-plugin-pipewire lib32-pipewire lib32-pipewire-jack pipewire pipewire-alsa pipewire-jack pipewire-pulse wireplumber pipewire-jack gnome gdm bluez-libs amd-ucode dbus-python glib2 gtk4 dconf nftables python-gobject hicolor-icon-theme libnotify nm-connection-editor python-pyqt6 bash-completion tesseract-data-eng mkinitcpio cronie pipewire-jack noto-fonts noto-fonts-emoji noto-fonts-cjk noto-fonts-extra gnu-free-fonts cmake meson nullmailer glibc gnome-extra gnome-firmware gnome-keyring polkit-gnome gnome-online-accounts flatpak gnome-console && 
arch-chroot /mnt pacman -R --noconfirm gedit gnome-terminal
#
elif [ $desktop0 == 'kde' ]
then
$pacmaninstall --noconfirm ark go xdg-desktop-portal-kde xorg-xwayland libpulse qt6-multimedia-ffmpeg lib32-libpulse alsa-plugins lib32-alsa-plugins alsa-lib lib32-alsa-lib zenity gst-plugin-pipewire lib32-pipewire lib32-pipewire-jack pipewire pipewire-alsa pipewire-jack pipewire-pulse wireplumber pipewire-jack plasma-framework bluez-libs amd-ucode dbus-python glib2 gtk4 dconf nftables python-gobject hicolor-icon-theme libnotify nm-connection-editor python-pyqt6 bash-completion qt6-imageformats tesseract-data-eng mkinitcpio cronie pipewire-jack noto-fonts noto-fonts-emoji noto-fonts-cjk noto-fonts-extra gnu-free-fonts cmake meson nullmailer glibc kcmutils archlinux-appstream-data appstream-qt plasma-wayland-session kuserfeedback knewstuff kidletime discount kirigami2 flatpak extra-cmake-modules plasma-wayland-protocols kde-applications-meta sddm sddm-kcm plasma-meta gnome-disk-utility qt6-wayland kscreen qt6
#
else
echo "You need to enter a valid desktop environment"
fi

#
echo "Installing Coffee Extras"
$pacmaninstall --noconfirm yay ttf-liberation chrony samba cups archivetools archiso qt6-multimedia-ffmpeg make unzip unrar xf86-video-amdgpu linux-headers sudo nano git base-devel dkms qt6 gnome-text-editor xreader vlc udev dbus gstreamer systemd ntp gst-libav gst-plugins-base gst-plugins-good gst-plugins-ugly gst-plugins-bad egl-wayland gtk-engine-murrine virtualbox-host-modules-arch power-profiles-daemon go meson xorg xorg-server xorg-apps lib32-libva-mesa-driver vulkan-radeon lib32-vulkan-radeon libva-utils libva-mesa-driver mesa-vdpau lib32-mesa-vdpau virtualbox virtualbox-guest-utils git xdg-utils gettext ufw libva-vdpau-driver neofetch wine winetricks lib32-vkd3d vkd3d innoextract giflib lib32-giflib libpng lib32-libpng libldap lib32-libldap gnutls lib32-gnutls mpg123 lib32-mpg123 openal lib32-openal v4l-utils lib32-v4l-utils  libjpeg-turbo lib32-libjpeg-turbo libxcomposite lib32-libxcomposite libxinerama lib32-libxinerama ncurses lib32-ncurses opencl-icd-loader lib32-opencl-icd-loader libxslt lib32-libxslt libva lib32-libva gst-plugins-base-libs lib32-gst-plugins-base-libs vulkan-icd-loader lib32-vulkan-icd-loader jre-openjdk-headless jre-openjdk jdk-openjdk openjdk-doc openjdk-src libreoffice-fresh firewalld shotwell lib32-libva-mesa-driver vulkan-radeon lib32-vulkan-radeon libva-utils libva-mesa-driver mesa-vdpau lib32-mesa-vdpau lib32-vulkan-mesa-layers opencl-mesa wine-mono wine-gecko vulkan-mesa-layers steam discord lib32-opencl-mesa mesa qt6-wayland mesa-utils &&
#
#Phase 2
arch-chroot /mnt archlinux-java set java-$java0-openjdk && 

#
echo -e '1\n' | $yayinstall mkinitcpio-firmware && 
echo -e '1\n' | $yayinstall text-engine-git && 
#Phase 3
arch-chroot /mnt pacman -Sy  && 
#
$systemdenable dhcpcd && 
$systemdenable cronie && 
$systemdenable chronyd &&
$systemdenable NetworkManager && 
arch-chroot /mnt systemctl --global enable pipewire.service pipewire-pulse.service wireplumber.service && 
$systemdenable firewalld
#
arch-chroot /mnt /bin/bash <<"EOT"
echo Installing Bootloader &&
mkinitcpio -P && 
#read -n 1 -s -r -p "Press any key to continue" &&  
bootctl install && 
echo 'default arch.conf' > /boot/loader/loader.conf && 
echo 'timeout 5' >> /boot/loader/loader.conf && 
echo 'console-mode max' >> /boot/loader/loader.conf && 
echo 'editor no' >> /boot/loader/loader.conf &&
echo $$
EOT

if [ $native1 == 'yes' ]
then
echo 'title Coffee-Linux "Grinder" (7.1.1)' > /mnt/boot/loader/entries/arch.conf
else
echo 'title Coffee-Linux "Grinder" (7.1.1-Unofficial)' > /mnt/boot/loader/entries/arch.conf
fi

echo 'linux /vmlinuz-linux' >> /mnt/boot/loader/entries/arch.conf &&
echo 'initrd /intel-ucode.img' >> /mnt/boot/loader/entries/arch.conf && 
echo 'initrd /amd-ucode.img' >> /mnt/boot/loader/entries/arch.conf && 
echo 'initrd /initramfs-linux.img' >> /mnt/boot/loader/entries/arch.conf &&


if [ $gpu0 == 'nvidia' ]
then

echo 'Installing Nvidia GPU drivers, and Control Panel.'

$pacmaninstall --noconfirm nvidia-dkms nvidia-utils nvidia-settings

echo options root="LABEL=$drivename0" rw nvidiadrm.modeset=1  >> /mnt/boot/loader/entries/arch.conf 

elif [ $gpu0 == 'intel' ]
then

echo 'Coffee Linux has not implimented Intel ARC GPUs yet so.. lets use the Default option for now.'

echo options root="LABEL=$drivename0" rw >> /mnt/boot/loader/entries/arch.conf

elif [ $gpu0 == 'amd' ]
then

echo 'AMD GPUs are supported by default. Installing a service level GPU Fan Controller instead.'

echo options root="LABEL=$drivename0" rw >> /mnt/boot/loader/entries/arch.conf 

echo -e '1\n' | $yayinstall amdgpu-fan

#arch-chroot /mnt systemctl enable amdgpu-fan

fi

echo -e '1\n' | $yayinstall protontricks && 
echo -e '1\n' | $yayinstall game-devices-udev &&
echo -e '1\n' | $yayinstall xone-dkms &&
echo -e '1\n' | $yayinstall microsoft-edge-stable && 
echo -e '2 7\n' | $yayinstall mangohud && 
echo -e '1\n' | $yayinstall gamescope && 
echo -e '2\n' | $yayinstall dxvk-bin
#

if [ $desktop0 == 'gnome' ]
then
#
if [ $native1 == 'yes' ]
then

rm -R /mnt/usr/share/backgrounds/gnome/ && 
mkdir -p /mnt/usr/share/backgrounds/gnome/ && 
cp /opt/backgrounds/coffee/adwaita-d.webp /mnt/usr/share/backgrounds/gnome/adwaita-d.webp && 
cp /opt/backgrounds/coffee/adwaita-l.webp /mnt/usr/share/backgrounds/gnome/adwaita-l.webp && 
cp /opt/backgrounds/coffee/grid-l.webp /mnt/usr/share/backgrounds/gnome/grid-l.webp && 
cp /opt/backgrounds/coffee/grid-d.webp /mnt/usr/share/backgrounds/gnome/grid-d.webp &&
cp /opt/backgrounds/coffee/licorice-l.webp /mnt/usr/share/backgrounds/gnome/licorice-l.webp && 
cp /opt/backgrounds/coffee/licorice-d.webp /mnt/usr/share/backgrounds/gnome/licorice-d.webp && 
cp /opt/backgrounds/coffee/wood-l.webp /mnt/usr/share/backgrounds/gnome/wood-l.webp && 
cp /opt/backgrounds/coffee/wood-d.webp /mnt/usr/share/backgrounds/gnome/wood-d.webp
else
echo ''
fi

#
echo 'Installing Coffee-QOL-Extras' && 
#
echo -e '1\n' | $yayinstall gnome-themes-extra && 
echo -e '1\n' | $yayinstall humanity-icon-theme && 
echo -e '1\n' | $yayinstall gnome-shell-extension-ubuntu-dock && 
echo -e '1\n' | $yayinstall gnome-shell-extension-appindicator && 
echo -e "1\n" | $yayinstall gnome-shell-extension-desktop-icons-ng && 
echo -e '1\n' | $yayinstall yaru-gtk-theme && 
echo -e '1\n' | $yayinstall yaru-icon-theme && 
echo -e '1\n' | $yayinstall yaru-gnome-shell-theme && 
echo -e '1\n' | $yayinstall yaru-session && 
echo -e '1\n' | $yayinstall yaru-sound-theme && 
echo -e '1\n' | $yayinstall yaru-unity-theme &&  
echo -e '1\n' | $yayinstall gdm-settings &&
arch-chroot /mnt pacman -Syu && 
rm -r /mnt/usr/share/xsessions/gnome* && 
rm -r /mnt/usr/share/wayland-sessions/gnome* && 
$systemdenable gdm
# 

elif [ $desktop0 == 'kde' ]
then  
#
echo 'Installing Coffee-QOL-Extras' &&  
 
echo -e '1\n' | $yayinstall systemd-kcm

if [ $native1 == 'yes' ]
then

mkdir -p /mnt/usr/share/wallpapers/coffee/ && 
#
cp /opt/backgrounds/coffee/coffeewall03.jpg /mnt/usr/share/wallpapers/coffee/coffeewall01.jpg && 
cp /opt/backgrounds/coffee/coffeewall05.jpg /mnt/usr/share/wallpapers/coffee/coffeewall02.jpg && 
cp /opt/backgrounds/coffee/coffeewall04.jpg /mnt/usr/share/wallpapers/coffee/coffeewall03.jpg && 
cp /opt/backgrounds/coffee/coffeewall06.jpg /mnt/usr/share/wallpapers/coffee/coffeewall04.jpg &&
cp /opt/backgrounds/coffee/coffeewall02.jpg /mnt/usr/share/wallpapers/coffee/coffeewall05.jpg && 
cp /opt/backgrounds/coffee/coffeewall07.jpg /mnt/usr/share/wallpapers/coffee/coffeewall06.jpg && 
cp /opt/backgrounds/coffee/coffeewall08.jpg /mnt/usr/share/wallpapers/coffee/coffeewall07.jpg && 
cp /opt/backgrounds/coffee/coffeewall01.jpg /mnt/usr/share/wallpapers/coffee/coffeewall08.jpg  
else
echo ''
fi

echo 'Ensuring correct DM is set.' &&  
$pacmaninstallu && 
$systemdenable sddm
#

fi

#Phase 5
echo 'Attempting to fix the home directory automatically now...' && 
$pacmaninstall --noconfirm xdg-user-dirs &&
arch-chroot /mnt xdg-user-dirs-update && 
echo 'Cleaning up' && 
arch-chroot /mnt systemctl daemon-reload && 
arch-chroot /mnt systemctl daemon-reexec 

if [ $native1 == 'yes' ]
then
cp /opt/os-release /mnt/etc/
#cp /usr/local/bin/coffeebrewer /mnt/opt/
else
echo ''
fi

#echo "Installation Complete, Please Reboot to use your OS." && 
#read -n 1 -s -r -p "Press any key to continue" && 
umount -R /mnt &&
reboot
#
################################
