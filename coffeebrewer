#!/bin/sh

printf "%b\n" "$*" | sudo -i

printf "%b\nSet your Username." "$*"
read -r user00
printf "%b\n$user00. Is this correct?" "$*"
printf "%b\n1 - yes" "$*"
printf "%b\n2 - no" "$*"
read -r usercheck
case $usercheck in
  1) printf "%b\nPerfect" "$*" ;;
  *) printf "%b\nLet's retry" "$*" ;;
  #*) printf "%b\nUnrecognized option, please try again: $user00" "$*" ;;
esac
if [ "$usercheck" = "1" ]; then
user01=$user00
fi

#
printf "%b\nSet your User Password." "$*"
read -r userpass00
printf "%b\n$userpass00. Is this correct?" "$*"
printf "%b\n1 - yes" "$*"
printf "%b\n2 - no" "$*"
read -r userpasscheck
case $userpasscheck in
  1) printf "%b\nPerfect" "$*" ;;
  *) printf "%b\nLet's retry" "$*" ;;
  #*) printf "%b\nUnrecognized option, please try again: $user00" "$*" ;;
esac
if [ "$userpasscheck" = "1" ]; then
userpass0=$userpass00
fi

#
printf "%b\nSet your Root Password." "$*"
read -r userpass01
printf "%b\n$userpass01. Is this correct?" "$*"
printf "%b\n1 - yes" "$*"
printf "%b\n2 - no" "$*"
read -r rootpasscheck
case $rootpasscheck in
  1) printf "%b\nPerfect" "$*" ;;
  *) printf "%b\nLet's retry" "$*" ;;
  #*) printf "%b\nUnrecognized option, please try again: $user00" "$*" ;;
esac
if [ "$rootpasscheck" = "1" ]; then
userpass1=$userpass01
fi
#
printf "%b\nWould you like to enable Secure-Boot in the OS?" "$*"
printf "%b\n1 - yes" "$*"
printf "%b\n2 - no" "$*"
read -r sbpasscheck
case $sbpasscheck in
  1) printf "%b\nPerfect" "$*" ;;
  2) printf "%b\nLet's move on then." "$*" ;;
  *) printf "%b\nUnrecognized option, please try again: $user00" "$*" ;;
esac

if [ "$sbpasscheck" = "1" ]; then
sbpass0=yes
elif [ "$sbpasscheck" = "2" ]; then
sbpass0=no
fi
#
if [ "$sbpass0" = "no" ]; then
printf "%b\nNo SB, skipping this part." "$*"
elif [ "$sbpass0" = "yes" ]; then
printf "%b\nSet your UEFI/MOK Secure-Boot Password." "$*"
read -r uefipass00
printf "%b\n$uefipass00. Is this correct?" "$*"
printf "%b\n1 - yes" "$*"
printf "%b\n2 - no" "$*"
read -r uefipasscheck
case $uefipasscheck in
  1) printf "%b\nPerfect" "$*" ;;
  *) printf "%b\nLet's retry" "$*" ;;
  #*) printf "%b\nUnrecognized option, please try again: $user00" "$*" ;;
esac
fi

if [ "$uefipasscheck" = "1" ]; then 
uefipass0=$uefipass00
fi

printf "%b\nSet your PC name." "$*"
read -r name00
printf "%b\n$name00. Is this correct?" "$*"
printf "%b\n1 - yes" "$*"
printf "%b\n2 - no" "$*"
read -r namepasscheck
case $namepasscheck in
  1) printf "%b\nPerfect" "$*" ;;
  *) printf "%b\nLet's retry" "$*" ;;
  #*) printf "%b\nUnrecognized option, please try again: $user00" "$*" ;;
esac
if [ "$namepasscheck" = "1" ]; then
name0=$name00
fi

#
printf "%b\nSet your HardDrive Label (OS Partition Label)." "$*"
read -r name01
printf "%b\n$name01. Is this correct?" "$*"
printf "%b\n1 - yes" "$*"
printf "%b\n2 - no" "$*"
read -r name2passcheck
case $name2passcheck in
  1) printf "%b\nPerfect" "$*" ;;
  *) printf "%b\nLet's retry" "$*" ;;
  #*) printf "%b\nUnrecognized option, please try again: $user00" "$*" ;;
esac
if [ "$name2passcheck" = "1" ]; then
name1=$name01
fi
#
printf "%b\nIs this a CoffeeLinux Installer .iso/USB?" "$*"
printf "%b\n1 - yes" "$*"
printf "%b\n2 - no" "$*"
read -r nativepasscheck
case $nativepasscheck in
  1) printf "%b\nPerfect" "$*" ;;
  2) printf "%b\nLet's move on then." "$*" ;;
  *) printf "%b\nUnrecognized option, please try again: $user00" "$*" ;;
esac
if [ "$nativepasscheck" = "1" ]; then
native1=yes
elif [ "$nativepasscheck" = "2" ]; then
native1=no
fi

printf "%b\nListing Storage Devices for you." "$*"
fdisk -l
printf "%b\n" "$*"
printf "%b\nWhich drive do you want Coffee Linux to install to?" "$*"
printf "%b\n1 - NVME0N1" "$*"
printf "%b\n2 - NVME1N1" "$*"
printf "%b\n3 - SDA" "$*"
printf "%b\n4 - SDB" "$*"
printf "%b\n5 - VDA" "$*"
printf "%b\n6 - VDB" "$*"

read -r driveX

if [ "$driveX" = "1" ]; then
drive="nvme0n1"
boot=p1
swap=p2
system=p3
elif [ "$driveX" = "2" ]; then
drive="nvme1n1"
boot=p1
swap=p2
system=p3
elif [ "$driveX" = "3" ]; then
drive="sda"
boot=1
swap=2
system=3
elif [ "$driveX" = "4" ]; then
drive="sdb"
boot=1
swap=2
system=3
elif [ "$driveX" = "5" ]; then
drive="vda"
boot=1
swap=2
system=3
elif [ "$driveX" = "6" ]; then
drive="vdb"
boot=1
swap=2
system=3
fi

printf "%b\n$drive. Is this correct?" "$*"
printf "%b\n1 - yes" "$*"
printf "%b\n2 - no" "$*"
read -r driveXpasscheck
case $driveXpasscheck in
  1) printf "%b\nPerfect" "$*" ;;
  *) printf "%b\nLet's retry" "$*" ;;
  #*) printf "%b\nUnrecognized option, please try again: $user00" "$*" ;;
esac

if [ "$driveXpasscheck" = "1" ]; then
pfx="/dev/"
drive0=$pfx$drive
boot0=$drive0$boot
swap0=$drive0$swap
system0=$drive0$system
hostname0=$name0
drivename0=$name1
fi
#
# Begin calculating Swap


printf "%b\nWould you like to enable hibernation?" "$*"
printf "%b\n1 - yes" "$*"
printf "%b\n2 - no" "$*"
read -r hibernationpasscheck
case $hibernationpasscheck in
  1) printf "%b\nPerfect" "$*" ;;
  2) printf "%b\nLet's move on then." "$*" ;;
  *) printf "%b\nUnrecognized option, please try again: $user00" "$*" ;;
esac

RAM=$(free -m | grep Mem | awk '{print $2}')

if [ "$hibernationpasscheck" = "1" ]; then
HIBERNATING=1
fi

if [ "$RAM" -gt 2048 ] && [ "$RAM" -lt 8192 ]; then # if RAM is between 2 and 8 GB
    
    if [ $HIBERNATING = 1 ]; then
        MULTIPLIER=3
    else
        MULTIPLIER=2
    fi
fi

if [ "$RAM" -gt 8192 ] && [ "$RAM" -lt 16384 ]; then # if RAM is between 8 and 16 GB
    if [ $HIBERNATING = 1 ]; then
        MULTIPLIER=2
    else
        MULTIPLIER=1
    fi
fi

if [ "$RAM" -gt 32768  ]; then    # if RAM is more than 32 GB
    if [ $HIBERNATING = 1 ]; then
        MULTIPLIER=1.5
    else
        MULTIPLIER=0.5
    fi
fi

printf "%b\nSetting up swap size, do you want to manually configure or auto configure it based on your RAM size ?" "$*"
printf "%b\n1 - Manual" "$*"
printf "%b\n2 - Auto" "$*"
read -r swapcheck # < - make this safer
case $swapcheck in
  1) printf "%b\nPerfect" "$*" ;;
  2) printf "%b\nLet's move on then." "$*" ;;
  *) printf "%b\nUnrecognized option, please try again: $user00" "$*" ;;
esac

if [ "$swapcheck" = "1" ]; then
    printf "%b\nEnter swap size in GB" "$*"
    read -r swapsize
    swapsize=$((swapsize))
    swap1=swapsize
elif [ "$swapcheck" = "2" ]; then
    swapsize=$((RAM*MULTIPLIER))
    swap1=swapsize
fi

#
printf "%b\nWhat desktop environment do you want?" "$*"
printf "%b\n1 - Gnome" "$*"
printf "%b\n2 - KDE" "$*"

read -r desktopcheck
case $desktopcheck in
  1) printf "%b\nPerfect" "$*" ;;
  2) printf "%b\nA good choice." "$*" ;;
  *) printf "%b\nUnrecognized option, please try again: $user00" "$*" ;;
esac
if [ "$desktopcheck" = "1" ]; then
desktop0="gnome"
elif [ "$desktopcheck" = "2" ]; then
desktop0="kde"
fi
#

#printf "%b\nSet the currently released major Java Version number -- 19 or newer."
#read javaver
java0=19


printf "%b\nDo you have an amd or nvidia graphics card? -- Intel ARC not yet supported." "$*"
printf "%b\n1 - AMD" "$*"
printf "%b\n2 - Nvidia" "$*"

read -r gpucheck
case $gpucheck in
  1) printf "%b\nPerfect" "$*" ;;
  2) printf "%b\nA good choice." "$*" ;;
  *) printf "%b\nUnrecognized option, please try again: $user00" "$*" ;;
esac
if [ "$gpucheck" = "1" ]; then
gpu0="amd"
elif [ "$desktopcheck" = "2" ]; then
gpu0="nvidia"
fi


printf "%b\nWould you like to Zero-Out the drive first?\nWARNING Zero-Out will take a long time, but has its benifits." "$*"
printf "%b\n1 - Yes" "$*"
printf "%b\n2 - No" "$*"
read -r zeroutcheck
case $zeroutcheck in
  1) printf "%b\nPerfect" "$*" ;;
  2) printf "%b\nA good choice." "$*" ;;
  *) printf "%b\nUnrecognized option, please try again: $user00" "$*" ;;
esac
if [ "$zeroutcheck" = "1" ]; then
zerout0="yes"
elif [ "$zeroutcheck" = "2" ]; then
zerout0="no"
fi
#
#Begin actual processing


if [ "$zerout0" = "yes" ]
then

printf "%b\nZero-Outing the drive... This will take quite a long time.." "$*" 

dd if=/dev/zero of=$drive0 bs=1M status=progress 

printf "%b\nZero-Out Complete." "$*"

printf "%b\nn\n1\n\n+2G\nn\n2\n\n+$swap1\nn\n3\n\n\nt\n1\n1\nt\n2\n19\nw" "$*" | fdisk -W always $drive0 

elif [ "$zerout0" = "no" ]
then
printf "%b\nn\n1\n\n+2G\nn\n2\n\n+$swap1\nn\n3\n\n\nt\n1\n1\nt\n2\n19\nw" "$*" | fdisk -W always $drive0 
fi

#
printf "%b\nFormatting Partitions" "$*"
mkfs.fat -F32 $boot0
mkswap $swap0
swapon $swap0
mkfs.btrfs -f -L "$drivename0" $system0 
printf "%b\nMounting Disks" "$*"
mount $system0 /mnt
mkdir /mnt/boot
mount $boot0 /mnt/boot
printf "%b\nEnable Repos" "$*"
printf "%b\n[multilib]\nInclude = /etc/pacman.d/mirrorlist\n[andontie-aur]\nServer = https://aur.andontie.net/'$'arch\nSigLevel = Never\n" "$*" >> /etc/pacman.conf
pacman -Sy --noconfirm archlinux-keyring
#
pacman -Syy
pacstrap /mnt base base-devel intel-ucode amd-ucode linux linux-firmware btrfs-progs net-tools networkmanager dhcpcd iwd man-pages man-db texinfo mkinitcpio sudo nano
arch-chroot /mnt pacman -Syy
arch-chroot /mnt pacman -Sy --noconfirm archlinux-keyring
cp /etc/pacman.conf /mnt/etc/pacman.conf
arch-chroot /mnt pacman -Syy
#
printf "%b\nSet Root Password" "$*"
printf "%b$userpass1\n$userpass1\n" "$*" | arch-chroot /mnt passwd 
printf "%bAdding User Account" "$*"
arch-chroot /mnt useradd -m -G wheel,audio,video,users --badname "$user01" 
printf "%b\nSet User Password" "$*"
printf "%b$userpass0\n$userpass0\n" "$*" | arch-chroot /mnt passwd "$user01"
printf "%b$hostname0" "$*" > /mnt/etc/hostname
printf "%b127.0.0.1 localhost\n::1 localhost\n127.0.1.1 $hostname0\n" "$*" >> /mnt/etc/hosts 
#
printf "%bCreating Links" "$*" 

genfstab -U /mnt >> /mnt/etc/fstab
arch-chroot /mnt /bin/bash << "EOT"
printf "%bSetting Locale" "$*"
ln -sf ../usr/share/zoneinfo/America/Los_Angeles /etc/localtime
hwclock --systohc
printf "%ben_US ISO-8859-1\nen_US.UTF-8 UTF-8\n" "$*" >> /etc/locale.gen
printf "%bKEYMAP=us\n" "$*" > /etc/vconsole.conf
printf "%bLANG=en_US.UTF-8\n" "$*" > /etc/locale.conf
export LANG=en_US.UTF-8
locale-gen
cd /
printf "%b%wheel ALL=(ALL:ALL) NOPASSWD: ALL" "$*" > /etc/sudoers.d/wheel
mkinitcpio -P
printf "%b\n" "$*"
EOT

#
cp --dereference /etc/resolv.conf /mnt/etc/
arch-chroot /mnt pacman -Syu --noconfirm
#

if [ $desktop0 = "gnome" ]; then
#
arch-chroot /mnt pacman -Sy --noconfirm file-roller bash-language-server shellcheck xdg-desktop-portal-gnome xorg-xwayland libpulse qt6 qt6-wayland qt6-multimedia-ffmpeg lib32-libpulse alsa-plugins lib32-alsa-plugins alsa-lib lib32-alsa-lib gtk4 zenity gst-plugin-pipewire lib32-pipewire lib32-pipewire-jack pipewire pipewire-alsa pipewire-jack pipewire-pulse wireplumber pipewire-jack gnome gdm bluez-libs amd-ucode dbus-python glib2 gtk4 dconf nftables python-gobject hicolor-icon-theme libnotify nm-connection-editor python-pyqt6 bash-completion tesseract-data-eng mkinitcpio cronie pipewire-jack noto-fonts noto-fonts-emoji noto-fonts-cjk noto-fonts-extra gnu-free-fonts cmake meson nullmailer glibc gnome-extra gnome-firmware gnome-keyring polkit-gnome gnome-online-accounts flatpak gnome-console gnome-text-editor shotwell gtk-engine-murrine colord ttf-ms-fonts ttf-vista-fonts gnome-color-manager libdrm libelf expat libglvnd libomxil-bellagio libunwind libxdamage libxshmfence libxxf86vm llvm-libs lm_sensors zstd libva-mesa-driver mesa-vdpau opengl-man-pages clang cmake directx-headers elfutils glslang libclc libva libvdpau libx11 libxml2 libxrandr llvm meson python-mako xorgproto valgrind systemd
arch-chroot /mnt pacman -R --noconfirm gedit gnome-terminal
#
elif [ $desktop0 = "kde" ]; then
arch-chroot /mnt pacman -Sy --noconfirm ark go bash-language-server shellcheck xdg-desktop-portal-kde xorg-xwayland libpulse qt6-multimedia-ffmpeg lib32-libpulse alsa-plugins lib32-alsa-plugins alsa-lib lib32-alsa-lib zenity gst-plugin-pipewire lib32-pipewire lib32-pipewire-jack pipewire pipewire-alsa pipewire-jack pipewire-pulse wireplumber pipewire-jack plasma-framework bluez-libs amd-ucode dbus-python glib2 dconf nftables python-gobject hicolor-icon-theme libnotify nm-connection-editor python-pyqt6 bash-completion qt6-imageformats tesseract-data-eng mkinitcpio cronie pipewire-jack noto-fonts noto-fonts-emoji noto-fonts-cjk noto-fonts-extra gnu-free-fonts cmake meson nullmailer glibc kcmutils appstream-qt plasma-wayland-session kuserfeedback knewstuff kidletime discount kirigami2 flatpak extra-cmake-modules plasma-wayland-protocols kde-applications-meta sddm sddm-kcm plasma-meta gnome-disk-utility qt6-wayland kscreen qt6 kvantum kgamma5 colord colord-kde ttf-ms-fonts ttf-vista-fonts kdevelop-python gtk-engine-murrine gtk4 gnome-color-manager libdrm libelf expat libglvnd libomxil-bellagio libunwind libxdamage libxshmfence libxxf86vm llvm-libs lm_sensors zstd libva-mesa-driver mesa-vdpau opengl-man-pages clang cmake directx-headers elfutils glslang libclc libva libvdpau libx11 libxml2 libxrandr llvm meson python-mako xorgproto valgrind systemd
#
fi

#
printf "%bInstalling Coffee Extras" "$*"
arch-chroot /mnt pacman -Sy --noconfirm yay ttf-liberation chrony samba cups archivetools archiso qt6-multimedia-ffmpeg make unzip unrar xf86-video-amdgpu linux-headers sudo nano git base-devel dkms qt6 xreader vlc udev dbus gstreamer systemd ntp gst-libav gst-plugins-base gst-plugins-good gst-plugins-ugly gst-plugins-bad egl-wayland virtualbox-host-modules-arch power-profiles-daemon go meson xorg xorg-server xorg-apps lib32-libva-mesa-driver vulkan-radeon lib32-vulkan-radeon libva-utils libva-mesa-driver mesa-vdpau lib32-mesa-vdpau virtualbox virtualbox-guest-utils git xdg-utils gettext ufw libva-vdpau-driver neofetch wine winetricks lib32-vkd3d vkd3d innoextract giflib lib32-giflib libpng lib32-libpng libldap lib32-libldap gnutls lib32-gnutls mpg123 lib32-mpg123 openal lib32-openal v4l-utils lib32-v4l-utils libjpeg-turbo lib32-libjpeg-turbo libxcomposite lib32-libxcomposite libxinerama lib32-libxinerama ncurses lib32-ncurses opencl-icd-loader lib32-opencl-icd-loader libxslt lib32-libxslt libva lib32-libva gst-plugins-base-libs lib32-gst-plugins-base-libs vulkan-icd-loader lib32-vulkan-icd-loader jre-openjdk-headless jre-openjdk jdk-openjdk openjdk-doc openjdk-src libreoffice-fresh firewalld lib32-libva-mesa-driver vulkan-radeon lib32-vulkan-radeon libva-utils libva-mesa-driver mesa-vdpau lib32-mesa-vdpau lib32-vulkan-mesa-layers opencl-mesa wine-mono wine-gecko vulkan-mesa-layers steam discord lib32-opencl-mesa mesa qt6-wayland mesa-utils exfatprogs ntfsprogs aria2 cabextract innoextract mtools dkms syslinux efibootmgr terminus-font
#
#Phase 2
arch-chroot /mnt archlinux-java set java-$java0-openjdk

#
printf "%b3\n" "$*" | arch-chroot /mnt sudo -Su "$user01" yay --noconfirm --nodiffmenu --noremovemake --answerclean y  --answerdiff y --answeredit y --answerupgrade y pamac-aur
printf "%b1\n" "$*" | arch-chroot /mnt sudo -Su "$user01" yay --noconfirm --nodiffmenu --noremovemake --answerclean y  --answerdiff y --answeredit y --answerupgrade y mkinitcpio-firmware
printf "%b1\n" "$*" | arch-chroot /mnt sudo -Su "$user01" yay --noconfirm --nodiffmenu --noremovemake --answerclean y  --answerdiff y --answeredit y --answerupgrade y text-engine-git

arch-chroot /mnt /bin/bash << "EOT"
printf "%bInstalling Bootloader" "$*"
mkinitcpio -P
bootctl install
printf "%bdefault arch.conf\ntimeout 5\nconsole-mode max\neditor no\n" "$*" > /boot/loader/loader.conf
EOT

if [ $native1 = "yes" ]; then
printf "%btitle Coffee-Linux 'Jubilee' (10.0.0)" "$*" > /mnt/boot/loader/entries/arch.conf
elif [ $native1 = "no" ]; then
printf "%btitle Coffee-Linux 'Jubilee' (10.0.0-Unofficial)" "$*" > /mnt/boot/loader/entries/arch.conf
fi

printf "%blinux /vmlinuz-linux\ninitrd /intel-ucode.img\ninitrd /amd-ucode.img\ninitrd /initramfs-linux.img\n" "$*" >> /mnt/boot/loader/entries/arch.conf

if [ $gpu0 = "nvidia" ]; then
printf "%bInstalling Nvidia GPU drivers, and Control Panel." "$*"
arch-chroot /mnt pacman -Sy --noconfirm nvidia-open opencl-nvidia nvidia-utils nvidia-settings
printf "%boptions root=LABEL=$drivename0 rw nvidia_drm.modeset=1 lsm=landlock,lockdown,yama,integrity,apparmor,bpf" "$*" >> /mnt/boot/loader/entries/arch.conf
elif [ $gpu0 = "amd" ]; then
printf "%bAMD GPUs are supported by default. Installing a service level GPU Fan Controller instead and CoreCtrl GUI." "$*"
printf "%boptions root=LABEL=$drivename0 rw lsm=landlock,lockdown,yama,integrity,apparmor,bpf" "$*" >> /mnt/boot/loader/entries/arch.conf
printf "%b1\n" "$*" | arch-chroot /mnt sudo -Su "$user01" yay --noconfirm --nodiffmenu --noremovemake --answerclean y  --answerdiff y --answeredit y --answerupgrade y amdgpu-fan
arch-chroot /mnt pacman -Sy --noconfirm corectrl
#arch-chroot /mnt systemctl enable amdgpu-fan
fi

if [ $sbpass0 = "yes" ]; then
printf "%bGenerating CoffeeLinux Secure-Boot keys for your machine" "$*"
arch-chroot /mnt pacman -Sy --noconfirm efitools mokutil sbsigntools apparmor sbctl
printf "%b1\n" "$*" | arch-chroot /mnt sudo -Su "$user01" yay --noconfirm --nodiffmenu --noremovemake --answerclean y  --answerdiff y --answeredit y --answerupgrade y shim-signed
printf "%b1\n" "$*" | arch-chroot /mnt sudo -Su "$user01" yay --noconfirm --nodiffmenu --noremovemake --answerclean y  --answerdiff y --answeredit y --answerupgrade y preloader-signed
printf "%b$uefipass0\n$uefipass0\n" "$*" | arch-chroot /mnt mokutil --password
printf "%b$uefipass0\n$uefipass0\n" "$*" | arch-chroot /mnt mokutil --reset
printf "%b$uefipass0\n$uefipass0\n" "$*" | arch-chroot /mnt mokutil --password

arch-chroot /mnt cp /usr/share/preloader-signed/PreLoader.efi /boot/EFI/systemd
arch-chroot /mnt cp /usr/share/preloader-signed/HashTool.efi /boot/EFI/systemd
arch-chroot /mnt cp /boot/EFI/systemd/systemd-bootx64.efi /boot/EFI/systemd/loader.efi
arch-chroot /mnt efibootmgr --unicode --disk $drive0 --part 1 --create --label "PreLoader" --loader /EFI/systemd/PreLoader.efi

arch-chroot /mnt mv /boot/EFI/BOOT/BOOTx64.EFI /boot/EFI/BOOT/grubx64.efi
arch-chroot /mnt cp /usr/share/shim-signed/shimx64.efi /boot/EFI/BOOT/BOOTx64.EFI
arch-chroot /mnt cp /usr/share/shim-signed/mmx64.efi /boot/EFI/BOOT/
arch-chroot /mnt efibootmgr --unicode --disk $drive0 --part 1 --create --label "Shim" --loader /EFI/BOOT/BOOTx64.EFI

arch-chroot /mnt openssl req -newkey rsa:4096 -nodes -keyout MOK.key -new -x509 -sha256 -days 3650 -subj "/CN=my Machine Owner Key/" -out MOK.crt
arch-chroot /mnt openssl x509 -outform DER -in MOK.crt -out MOK.cer
arch-chroot /mnt sbsign --key MOK.key --cert MOK.crt --output /boot/vmlinuz-linux /boot/vmlinuz-linux
arch-chroot /mnt sbsign --key MOK.key --cert MOK.crt --output /boot/EFI/BOOT/grubx64.efi /boot/EFI/BOOT/grubx64.efi
cp /opt/999-sign_kernel_for_secureboot.hook /mnt/etc/pacman.d/hooks/999-sign_kernel_for_secureboot.hook
arch-chroot /mnt cp MOK.cer /boot/
arch-chroot /mnt cp MOK.crt /boot/
arch-chroot /mnt cp MOK.key /boot/
arch-chroot /mnt pacman -Sy
arch-chroot /mnt systemctl enable apparmor
arch-chroot /mnt systemctl enable systemd-boot-update.service
arch-chroot /mnt systemctl enable dhcpcd
arch-chroot /mnt systemctl enable cronie
arch-chroot /mnt systemctl enable chronyd
arch-chroot /mnt systemctl enable NetworkManager
arch-chroot /mnt systemctl --global enable pipewire.service pipewire-pulse.service wireplumber.service
arch-chroot /mnt systemctl enable firewalld
elif [ $sbpass0 = "no" ]; then
printf "%bAdding AppArmor" "$*"
arch-chroot /mnt pacman -Sy --noconfirm apparmor
arch-chroot /mnt systemctl enable apparmor
arch-chroot /mnt systemctl enable systemd-boot-update.service
arch-chroot /mnt systemctl enable dhcpcd
arch-chroot /mnt systemctl enable cronie
arch-chroot /mnt systemctl enable chronyd
arch-chroot /mnt systemctl enable NetworkManager
arch-chroot /mnt systemctl --global enable pipewire.service pipewire-pulse.service wireplumber.service
arch-chroot /mnt systemctl enable firewalld
fi

printf "%b1\n" "$*" | arch-chroot /mnt sudo -Su "$user01" yay --noconfirm --nodiffmenu --noremovemake --answerclean y  --answerdiff y --answeredit y --answerupgrade y protontricks
