#!/bin/sh
#Phase 1
#
#echo "This script/command must be run directly as root user not via sudo. (ie: entering sudo -i first)"
#echo "If you have not ran as root user, please exit now, root, and run again."
#
echo "Set your Username."
read user00
user01=$user00
#
echo "Set your drive ('nvme0n1 or nvme1n1 / sda or sdb')"
read drive
pfx="/dev/"
drive0=$pfx$drive
#

if [ $drive == 'nvme0n1' ]
then
boot=p1
swap=p2
system=p3
elif [ $drive == 'nvme1n1' ]
then
boot=p1
swap=p2
system=p3
elif [ $drive == 'sda' ]
then
boot=1
swap=2
system=3
elif [ $drive == 'sdb' ]
then
boot=1
swap=2
system=3
else
echo 'You need to enter a valid drive'
fi

#
boot0=$drive0$boot
#
swap0=$drive0$swap
#
system0=$drive0$system
#
hostname0=CoffeeLinux
#
drivename0=CoffeePot
#
echo "Set your Swap Size (ie: 8G for 8 Gigagytes of swapspace. )."
read swapsize
swap1=$swapsize
#
echo "What dektop environment would you like? ('gnome, kde, or cinnamon (case-sensitive)')."
read desktop0
#
(
echo g # Create a new empty DOS partition table
echo n # Add a new partition
echo 1 # Partition number
echo   # First sector (Accept default: 1)
echo +2G # Last sector (Accept default: varies)
echo 2 # Partition number
echo   # First sector (Accept default: 1)
echo +$swap1 # Last sector (Accept default: varies)
echo 3 # Partition number
echo   # First sector (Accept default: 1)
echo   # Last sector (Accept default: varies)
echo t # Set EFI to the new partition
echo 1 # Partition number
echo 1 # Partition type (Accept default: 1)
echo t # Set EFI to the new partition
echo 2 # Partition number
echo 19 # Partition type (Accept default: 1)
echo w # Write changes
) | fdisk $drive0
#
echo 'Formatting Partitions' && 
mkfs.fat -F32 $boot0 && 
mkswap $swap0
swapon $swap0
mkfs.btrfs -L $drivename0 $system0 && 
echo 'Mounting Disks' && 
mount $system0 /mnt && 
mkdir /mnt/boot && 
mount $boot0 /mnt/boot && 
echo 'Enable Repos' &&
echo '' >> /etc/pacman.conf &&
echo '[multilib]' >> /etc/pacman.conf && 
echo 'Include = /etc/pacman.d/mirrorlist' >> /etc/pacman.conf &&
echo '' >> /etc/pacman.conf &&
echo '[andontie-aur]' >> /etc/pacman.conf &&
echo 'Server = https://aur.andontie.net/$arch' >> /etc/pacman.conf &&
echo 'SigLevel = Never' >> /etc/pacman.conf &&
echo '' >> /etc/pacman.conf &&
pacman -Sy --noconfirm archlinux-keyring && 
pacman -Sy --noconfirm archlinux-appstream-data && 
#
#echo 'Installing Kernel Frameworks' && 
pacman -Syy && 
pacstrap /mnt base intel-ucode amd-ucode linux linux-firmware btrfs-progs net-tools networkmanager dhcpcd iwd man-pages man-db texinfo mkinitcpio sudo nano && 
arch-chroot /mnt pacman -Syy &&
arch-chroot /mnt pacman -Sy --noconfirm archlinux-keyring &&
cp /etc/pacman.conf /mnt/etc/pacman.conf &&
arch-chroot /mnt pacman -Syy &&
#
echo 'Set Root Password' && 
arch-chroot /mnt passwd && 
echo 'Adding User Account' && 
arch-chroot /mnt useradd -m -G wheel,audio,video,users --badname $user01 && 
echo 'Set User Password' && 
arch-chroot /mnt passwd $user01
echo $hostname0 > /mnt/etc/hostname && 
echo '127.0.0.1 localhost' >> /mnt/etc/hosts && 
echo '::1 localhost' >> /mnt/etc/hosts && 
echo 127.0.1.1 $hostname0 >> /mnt/etc/hosts && 
#
echo 'Creating Links' && 
genfstab -U /mnt >> /mnt/etc/fstab &&
arch-chroot /mnt /bin/bash <<"EOT"
